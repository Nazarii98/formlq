rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isEditor() {
      return isAuth() && role() == "editor";
    }

    function isTutor() {
      return isAuth() && (role() == "tutor" || role() == "editor");
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Accounts that must always stay editor (keep in sync with PROTECTED_EMAILS in src/lib/users.ts)
    function protectedEmails() {
      return ["nazariichepil@gmail.com"];
    }
    // Block any write to a protected user's doc that would change their role away from editor.
    function protectedRoleOk() {
      return !(
        resource != null
        && (resource.data.email in protectedEmails())
        && request.resource.data.role != "editor"
      );
    }

    // True when the given homework doc belongs to the current tutor.
    function ownsHomework(hwId) {
      return isAuth() &&
        get(/databases/$(database)/documents/homework/$(hwId)).data.tutorId == request.auth.uid;
    }

    // Users — any signed-in user may read profiles (needed to find students by email);
    // writes only by the owner or an editor.
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if (isOwner(uid) || isEditor()) && protectedRoleOk();
    }

    // Tests — read by any auth user, write by editors only
    match /tests/{testId} {
      allow read: if isAuth();
      allow write: if isEditor();
    }

    // Test results
    match /testResults/{resultId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isEditor()
        || (isTutor() && ("homeworkId" in resource.data) && ownsHomework(resource.data.homeworkId))
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Owner may update their own result (e.g. duck flags); the owning tutor may add comments.
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isEditor()
        || (isTutor() && ("homeworkId" in resource.data) && ownsHomework(resource.data.homeworkId))
      );
      allow delete: if isEditor();
    }

    // Homework assignments
    match /homework/{hwId} {
      allow read: if isAuth() && (
        resource.data.tutorId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isEditor()
      );
      allow create: if isTutor() && request.resource.data.tutorId == request.auth.uid;
      // Tutor owns it; student may update their own (status, resultId) on submit.
      allow update: if isAuth() && (
        resource.data.tutorId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isEditor()
      );
      allow delete: if isAuth() && (resource.data.tutorId == request.auth.uid || isEditor());
    }

    // Tutor ↔ student links
    match /tutorStudents/{linkId} {
      // resource == null allows reading a not-yet-existing link (the dup-check before create)
      allow read: if isAuth() && (
        resource == null
        || resource.data.tutorId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isEditor()
      );
      allow create: if isEditor() || (isTutor() && request.resource.data.tutorId == request.auth.uid);
      allow delete: if isAuth() && (resource.data.tutorId == request.auth.uid || isEditor());
    }

    // Lessons (calendar)
    match /lessons/{lessonId} {
      allow read: if isAuth() && (
        resource.data.tutorId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isEditor()
      );
      allow create: if isEditor() || (isTutor() && request.resource.data.tutorId == request.auth.uid);
      allow update, delete: if isAuth() && (resource.data.tutorId == request.auth.uid || isEditor());
    }

    // Tips — read by any auth user, write by editors only
    match /tips/{tipId} {
      allow read: if isAuth();
      allow write: if isEditor();
    }

    // Questions bank — read by any auth user, write by editors only
    match /questions/{questionId} {
      allow read: if isAuth();
      allow write: if isEditor();
    }

    // Daily answers — read/create by owner, read by editor
    match /dailyAnswers/{docId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isEditor()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isEditor();
    }
  }
}
